{
  "manifest_version": 3,
  "name": "WebHID",
  "version": "1.0",

  "description": "WebHID Support for Firefox",

  "icons": {
    "48": "icons/icon-48.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*"],
      "js": ["borderify.js"]
    }
  ],

  "permissions": [
    "nativeMessaging"
  ]
}
