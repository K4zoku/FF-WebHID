<?xml version='1.0' encoding='utf-8'?>
<!--
  WebHID Windows Installer (MSI)
  Built with WiX Toolset v6.

  Layout:
    [ProgramFiles64Folder]WebHID\
      webhid-daemon.exe
      webhid-native-messaging.exe
      webhid-native-messaging-host.json   (NM manifest, [INSTALLDIR] resolved at install time)

  Registry:
    HKLM\SOFTWARE\Mozilla\NativeMessagingHosts\webhid-native-messaging-host  = [INSTALLDIR]webhid-native-messaging-host.json

  Scheduled Task:
    "WebHID Daemon": runs at logon, webhid-daemon.exe
-->
<Wix xmlns='http://wixtoolset.org/schemas/v4/wxs'>
  <Package Name='WebHID'
           Manufacturer='K4zoku'
           Language='1033'
           Version='$(var.Version)'
           UpgradeCode='7c7e8f5a-3d2b-4e6f-9a1c-8b5d6e7f8a90'>

    <SummaryInformation Description='WebHID daemon + native messaging host'
                        Manufacturer='K4zoku'/>

    <Media Id='1' Cabinet='webhid.cab' EmbedCab='yes'/>

    <MajorUpgrade DowngradeErrorMessage='A newer version of WebHID is already installed.'/>

    <Feature Id='Complete' Title='WebHID' Level='1'>
      <ComponentGroupRef Id='Binaries'/>
      <ComponentGroupRef Id='Registry'/>
    </Feature>

    <Launch Condition='Privileged' Message='This installer requires administrator privileges.'/>

    <CustomAction Id='CreateTask'
                  Directory='INSTALLDIR'
                  ExeCommand='powershell.exe -NoProfile -NonInteractive -Command &quot;Register-ScheduledTask -TaskName \&quot;WebHID Daemon\&quot; -Action (New-ScheduledTaskAction -Execute \&quot;[INSTALLDIR]webhid-daemon.exe\&quot;) -Trigger (New-ScheduledTaskTrigger -AtLogOn) -Settings (New-ScheduledTaskSettingsSet -RestartCount 3 -RestartInterval (New-TimeSpan -Minutes 1)) -Force&quot;'
                  Return='check'/>
    <CustomAction Id='DeleteTask'
                  Directory='INSTALLDIR'
                  ExeCommand='powershell.exe -NoProfile -NonInteractive -Command &quot;Unregister-ScheduledTask -TaskName \&quot;WebHID Daemon\&quot; -Confirm:$false&quot;'
                  Return='ignore'/>

    <InstallExecuteSequence>
      <Custom Action='CreateTask' After='InstallFiles' Condition='NOT Installed'/>
      <Custom Action='DeleteTask' Before='RemoveFiles' Condition='Installed'/>
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <StandardDirectory Id='ProgramFiles64Folder'>
      <Directory Id='INSTALLDIR' Name='WebHID'>
        <Component Id='DaemonBin' Guid='a1b2c3d4-1111-2222-3333-444455556666'>
          <File Id='DaemonExe' Source='$(var.BuildDir)\webhid-daemon.exe' KeyPath='yes'/>
        </Component>
        <Component Id='NMBin' Guid='a1b2c3d4-1111-2222-3333-444455557777'>
          <File Id='NMExe' Source='$(var.BuildDir)\webhid-native-messaging.exe' KeyPath='yes'/>
        </Component>
        <Component Id='NMManifest' Guid='a1b2c3d4-1111-2222-3333-444455558888'>
          <File Id='NMJson' Name='webhid-native-messaging-host.json'
                Source='$(var.BuildDir)\webhid-native-messaging-host.json' KeyPath='yes'/>
        </Component>
        <Component Id='NMRegistry' Guid='a1b2c3d4-1111-2222-3333-444455559999'>
          <RegistryKey Root='HKLM'
                       Key='SOFTWARE\Mozilla\NativeMessagingHosts\webhid-native-messaging-host'>
            <RegistryValue Type='string' Value='[INSTALLDIR]webhid-native-messaging-host.json' KeyPath='yes'/>
          </RegistryKey>
        </Component>
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id='Binaries'>
      <ComponentRef Id='DaemonBin'/>
      <ComponentRef Id='NMBin'/>
      <ComponentRef Id='NMManifest'/>
    </ComponentGroup>
    <ComponentGroup Id='Registry'>
      <ComponentRef Id='NMRegistry'/>
    </ComponentGroup>
  </Fragment>
</Wix>
