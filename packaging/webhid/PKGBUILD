# Maintainer: K4zoku <k4zoku@pm.me>
#
# Build & install:
#   cd packaging/webhid
#   makepkg -si
#
# This PKGBUILD lives two levels below the project root
# (packaging/webhid/PKGBUILD), so every function uses
# "$startdir/../.." to reach the repository root.
#
# Build & install logic lives in the repository Makefile; this PKGBUILD
# just drives it with Arch-appropriate paths and handles the multi-browser
# native-messaging layout that the Makefile does not cover.

pkgname=webhid
pkgver=0.1.0
pkgrel=1
pkgdesc='WebHID implementation for Firefox via a native-messaging bridge and hidraw daemon'
arch=('x86_64' 'aarch64')
url='https://github.com/k4zoku/FF-WebHID'
license=('MIT')
# libudev is provided by systemd on Arch Linux; hidapi is built from source
depends=('libudev.so')
makedepends=('cargo' 'pkgconf')
optdepends=('webhid-addon: Firefox browser extension (system-wide install)')
install=webhid.install
# No source array – we build directly from the repository tree via startdir.
# The Cargo workspace lives at  <repo>/crates/Cargo.toml
source=()
sha256sums=()

# Silence makepkg's "strip" pass; Rust release builds are already optimised
# and stripping the debug-info section is handled by the Rust toolchain.
options=('!lto' '!debug')

_root() { echo "$startdir/../.."; }

prepare() {
    # Pre-download all crate dependencies into the local cargo registry so
    # the build() step can run with --frozen (no further network I/O).
    cargo fetch \
        --target "$CARCH-unknown-linux-gnu" \
        --manifest-path "$(_root)/crates/Cargo.toml"
}

build() {
    # Build via Makefile, passing --frozen for makepkg reproducibility.
    make -C "$(_root)" build CARGO_ARGS=--frozen
}

package() {
    local _root="$(_root)"

    # ------------------------------------------------------------------ #
    # Binaries + systemd unit + NM manifest (Firefox path)
    #
    # The Makefile's install-system substitutes the {{DAEMON_BIN}} and
    # {{NM_BIN}} placeholders in the templates from manifests/ with the
    # real install paths, so there is a single source of truth.
    # ------------------------------------------------------------------ #
    make -C "$_root" install-system DESTDIR="$pkgdir" \
        PREFIX=/usr \
        SYSTEMD_DIR=/usr/lib/systemd/system \
        SYSTEM_NM_DIR=/usr/lib/mozilla/native-messaging-hosts

    # ------------------------------------------------------------------ #
    # Native-messaging manifest for other Gecko-based browsers.
    #
    # The Makefile already installed the manifest (with the correct
    # /usr/bin path) into the Firefox search path.  Copy the same file
    # into the LibreWolf and Waterfox search paths – mirroring
    # plasma-browser-integration's approach.
    # ------------------------------------------------------------------ #
    local _nm="$pkgdir/usr/lib/mozilla/native-messaging-hosts/webhid_server.json"
    install -Dm644 "$_nm" \
        "$pkgdir/usr/lib/librewolf/native-messaging-hosts/webhid_server.json"
    install -Dm644 "$_nm" \
        "$pkgdir/usr/lib/waterfox/native-messaging-hosts/webhid_server.json"

    # ------------------------------------------------------------------ #
    # License
    # ------------------------------------------------------------------ #
    install -Dm644 "$_root/LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
