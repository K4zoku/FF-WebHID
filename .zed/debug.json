// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
      "label": "Debug",
      "build": {
        "command": "cargo",
        "args": ["build", "--manifest-path", "crates/Cargo.toml"],
        "cwd": "$ZED_WORKTREE_ROOT"
      },
      "program": "$ZED_WORKTREE_ROOT/crates/target/debug/webhid-daemon",
      "request": "launch",
      "adapter": "CodeLLDB"
    }
]
