  {
      "label": "Debug",
      "build": {
        "command": "meson",
        "args": ["compile", "-C", "build"],
        "cwd": "$ZED_WORKTREE_ROOT/server"
      },
      "program": "$ZED_WORKTREE_ROOT/server/build/WebHIDServer",
      "request": "launch",
      "adapter": "CodeLLDB"
    }
]
