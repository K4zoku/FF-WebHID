[
  {
    "label": "Build",
    "command": "cargo",
    "args": ["build", "--manifest-path", "crates/Cargo.toml"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "no_focus",
    "hide": "never",
    "shell": "system",
    "show_summary": true,
    "show_command": true,
    "tags": ["build"],
  },
  {
    "label": "Run",
    "command": "pkexec",
    "args": ["./webhid-daemon"],
    "cwd": "$ZED_WORKTREE_ROOT/crates/target/debug",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "shell": "system",
    "show_summary": true,
    "show_command": false,
    "tags": ["run", "daemon"]
  }
]
