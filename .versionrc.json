{
  "packageFiles": [
    { "filename": ".version.json", "type": "json" }
  ],
  "bumpFiles": [
    { "filename": ".version.json", "type": "json" },
    { "filename": "package.json", "type": "json" },
    { "filename": "addon/manifest.json", "type": "json" },
    { "filename": "crates/webhid/Cargo.toml", "updater": ".versionrc.cargo-updater.cjs" },
    { "filename": "crates/webhid-daemon/Cargo.toml", "updater": ".versionrc.cargo-updater.cjs" },
    { "filename": "crates/webhid-native-messaging/Cargo.toml", "updater": ".versionrc.cargo-updater.cjs" }
  ],
  "types": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "docs", "section": "Documentation" },
    { "type": "ci", "section": "CI/CD" },
    { "type": "chore", "section": "Chores" }
  ],
  "releaseCommitMessageFormat": "chore: release v{{currentTag}}"
}
