# Grant console users access to hidraw devices for the WebHID daemon, excluding
# known FIDO/U2F security keys (matches Chromium's hid_blocklist.cc one-to-one).
#
# FIDO usage-page (0xF1D0) catch-all cannot be expressed in udev (no usage-page
# attribute in sysfs); the daemon enforces that at runtime.
# Keyboard/mouse/system-control blocks are also daemon-enforced per project design.
#
# Source: chromium/src/+/main/services/device/public/cpp/hid/hid_blocklist.cc

KERNEL=="hidraw*", TAG+="uaccess"

# KEY-ID / Feitian
KERNEL=="hidraw*", ATTRS{idVendor}=="096e", ATTRS{idProduct}=="0850", TAG-="uaccess"
KERNEL=="hidraw*", ATTRS{idVendor}=="096e", ATTRS{idProduct}=="0852", TAG-="uaccess"
